# 复制为 .env 并填入真实值。真实 .env 绝不提交进仓库。

# 本地 PostgreSQL（docker compose up -d 启动，默认值开箱即用）
DATABASE_URL=postgresql://educanvas:educanvas@localhost:5432/educanvas

# 模型供应商适配器。默认不启用；不要在示例文件或客户端代码中填写真实 Key。
EDUCANVAS_DEPLOYMENT_ENV=local
MODEL_GATEWAY_PROVIDER=
MODEL_GATEWAY_ALLOW_DEEPSEEK=false
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=

# 模型 ID 必须显式配置，不在代码中内置供应商型号。
MODEL_GATEWAY_PRIMARY_MODEL=
MODEL_GATEWAY_FAST_MODEL=
MODEL_GATEWAY_STRUCTURED_MODEL=
MODEL_GATEWAY_TIMEOUT_MS=30000
MODEL_GATEWAY_MAX_OUTPUT_TOKENS=2048

# 网页搜索工具(M3):未配置时工具不注册,通用对话行为与无工具一致
SEARCH_API_KEY=
# 可选,默认 https://api.tavily.com
SEARCH_BASE_URL=
