# Copy this file to .env and fill in local values. Never commit .env.

# Local PostgreSQL (docker compose up -d; the default works out of the box)
DATABASE_URL=postgresql://educanvas:educanvas@localhost:5432/educanvas

# Model provider adapter. Disabled by default; never put a real key here.
EDUCANVAS_DEPLOYMENT_ENV=local
MODEL_GATEWAY_PROVIDER=
# Turn adapter: native (default) or ai-sdk; no silent fallback.
MODEL_GATEWAY_RUNTIME=native
MODEL_GATEWAY_ALLOW_DEEPSEEK=false
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=

# Model IDs must be configured explicitly; provider model names are not bundled.
MODEL_GATEWAY_PRIMARY_MODEL=
MODEL_GATEWAY_FAST_MODEL=
MODEL_GATEWAY_STRUCTURED_MODEL=
MODEL_GATEWAY_SPEECH_MODEL=
MODEL_GATEWAY_SPEECH_VOICE=alloy
MODEL_GATEWAY_SPEECH_TIMEOUT_MS=60000
MODEL_GATEWAY_SPEECH_MAX_INPUT_CHARS=3500
MODEL_GATEWAY_TIMEOUT_MS=30000
MODEL_GATEWAY_MAX_OUTPUT_TOKENS=2048

# OpenTelemetry is disabled by default; exported data never includes prompts, tokens, or secrets.
EDUCANVAS_OTEL_ENABLED=false
EDUCANVAS_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
# Optional controlled headers JSON; keep real tokens in local secrets only.
EDUCANVAS_OTEL_EXPORTER_HEADERS_JSON=
EDUCANVAS_OTEL_SAMPLE_RATIO=0.1
EDUCANVAS_OTEL_EXPORT_TIMEOUT_MS=3000

# Web search tool (M3): disabled when no key is configured.
SEARCH_API_KEY=
# Optional; defaults to https://api.tavily.com
SEARCH_BASE_URL=

# Gateway. Listens on loopback by default; tokens/secrets must be at least 32 bytes.
# Without auth values, only health checks and internal shutdown are available.
EDUCANVAS_GATEWAY_HOST=127.0.0.1
EDUCANVAS_GATEWAY_PORT=3200
EDUCANVAS_GATEWAY_URL=http://127.0.0.1:3200
EDUCANVAS_GATEWAY_INTERNAL_TOKEN=
EDUCANVAS_GATEWAY_BOOTSTRAP_TOKEN=
EDUCANVAS_GATEWAY_SESSION_SECRET=
# Shared local Web/TUI development identity; loopback onboarding only.
EDUCANVAS_LOCAL_USER_ID=local:owner

# Telegram username for control-plane deep links; the bot token is adapter-only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Capability Node read-only root mapping, for example {"notes":"/Users/me/Notes"}.
# Node supports controlled list/read only; it has no shell or write capability.
EDUCANVAS_NODE_READ_ROOTS_JSON={}

# Trusted MCP v1 Streamable HTTP registrations. Disabled by default; never put tokens here.
# Bearer tools must use opaque handles resolved by an independent Credential Broker.
EDUCANVAS_MCP_TOOLS_JSON=[]
# Required only for L2/L3 MCP; inject a random 32-byte base64 secret at deployment time.
EDUCANVAS_MCP_INTENT_ENCRYPTION_KEY=
