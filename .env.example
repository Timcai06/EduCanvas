# 复制为 .env 并填入真实值。真实 .env 绝不提交进仓库。

# 本地 PostgreSQL（docker compose up -d 启动，默认值开箱即用）
DATABASE_URL=postgresql://educanvas:educanvas@localhost:5432/educanvas

# 模型供应商适配器。默认不启用；不要在示例文件或客户端代码中填写真实 Key。
EDUCANVAS_DEPLOYMENT_ENV=local
MODEL_GATEWAY_PROVIDER=
# Turn Adapter实现：native（默认回滚路径）或ai-sdk；不会自动静默切换。
MODEL_GATEWAY_RUNTIME=native
MODEL_GATEWAY_ALLOW_DEEPSEEK=false
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=

# 模型 ID 必须显式配置，不在代码中内置供应商型号。
MODEL_GATEWAY_PRIMARY_MODEL=
MODEL_GATEWAY_FAST_MODEL=
MODEL_GATEWAY_STRUCTURED_MODEL=
MODEL_GATEWAY_SPEECH_MODEL=
MODEL_GATEWAY_SPEECH_VOICE=alloy
MODEL_GATEWAY_SPEECH_TIMEOUT_MS=60000
MODEL_GATEWAY_SPEECH_MAX_INPUT_CHARS=3500
MODEL_GATEWAY_TIMEOUT_MS=30000
MODEL_GATEWAY_MAX_OUTPUT_TOKENS=2048

# OpenTelemetry默认关闭；启用后只导出白名单span/event，不记录正文、Prompt、Token或Secret。
EDUCANVAS_OTEL_ENABLED=false
EDUCANVAS_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
# 可选受控Header JSON；真实Token只放本地Secret，绝不提交。
EDUCANVAS_OTEL_EXPORTER_HEADERS_JSON=
EDUCANVAS_OTEL_SAMPLE_RATIO=0.1
EDUCANVAS_OTEL_EXPORT_TIMEOUT_MS=3000

# 网页搜索工具(M3):未配置时工具不注册,通用对话行为与无工具一致
SEARCH_API_KEY=
# 可选,默认 https://api.tavily.com
SEARCH_BASE_URL=

# Gateway。默认仅监听本机；三项令牌/密钥均至少 32 字节。
# 不配置认证项时，Gateway 只提供健康检查和内部关闭状态，公共客户端/Node 不开放。
EDUCANVAS_GATEWAY_HOST=127.0.0.1
EDUCANVAS_GATEWAY_PORT=3200
EDUCANVAS_GATEWAY_URL=http://127.0.0.1:3200
EDUCANVAS_GATEWAY_INTERNAL_TOKEN=
EDUCANVAS_GATEWAY_BOOTSTRAP_TOKEN=
EDUCANVAS_GATEWAY_SESSION_SECRET=
# 本地 Web/TUI 共享的开发主体；仅 loopback + local onboarding 使用。
EDUCANVAS_LOCAL_USER_ID=local:owner

# Telegram username 供控制面生成 deep link；Bot Token 只供单独运行的 Adapter 使用。
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Capability Node 可读根目录映射，例如 {"notes":"/Users/me/Notes"}。
# Node 仅支持受控的只读 list/read，不提供 shell 或写文件能力。
EDUCANVAS_NODE_READ_ROOTS_JSON={}

# MCP v1 Streamable HTTP 工具的服务端可信注册数组。默认关闭；不要写入Token，
# bearer工具必须由独立Credential Broker按用户和Personal Agent解析不透明句柄。
EDUCANVAS_MCP_TOOLS_JSON=[]
# 仅L2/L3 MCP需要；32字节随机值的base64，必须由部署Secret注入，禁止提交真实值。
EDUCANVAS_MCP_INTENT_ENCRYPTION_KEY=
