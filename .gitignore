# macOS
.DS_Store

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key

# JavaScript / TypeScript
node_modules/
.next/
dist/
build/
coverage/
.turbo/
.pnpm-store/
/output/playwright/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Editors（.vscode 里共享的两个配置文件例外，用于统一团队编辑器行为）
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# Claude Code — 共享团队配置，保留个人覆盖
# .claude/ 下默认全部忽略，仅白名单共享 settings.json、commands/、rules/、skills/、agents/
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/rules/
!.claude/skills/
!.claude/agents/
.claude/settings.local.json
CLAUDE.local.md

# Logs and temporary files
*.log
logs/
tmp/
temp/
.omx/

# Local runtime data and large generated artifacts
# 注意：只匹配仓库根目录，避免误伤 packages/canvas-protocol/src/artifacts/ 等源码目录
/uploads/
/models/
/checkpoints/
/artifacts/

# TypeScript incremental build info
*.tsbuildinfo

# 个人学习笔记
notes/
