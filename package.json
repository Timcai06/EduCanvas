{
  "name": "educanvas",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm dev:core",
    "dev:core": "turbo dev --filter=@educanvas/web --filter=@educanvas/worker --filter=@educanvas/gateway",
    "dev:all": "pnpm dev:core",
    "build": "turbo build",
    "lint": "turbo lint && pnpm lint:format",
    "lint:format": "prettier --check \"apps/**/*.{js,mjs,cjs,ts,tsx}\" \"packages/**/*.{js,mjs,cjs,ts,tsx}\" \"tooling/**/*.{js,mjs,cjs,ts,tsx}\" \"*.{js,mjs,cjs,ts,tsx}\"",
    "env:check": "node tooling/env-check.mjs",
    "setup:local": "pnpm install --frozen-lockfile && pnpm db:up && pnpm db:migrate",
    "start:local": "node tooling/local-orchestrator.mjs web",
    "test": "pnpm test:unit",
    "test:unit": "pnpm test:tooling && turbo test",
    "test:tooling": "node --test tooling/*.test.mjs",
    "test:integration": "turbo test:integration --filter=@educanvas/db --filter=@educanvas/worker --concurrency=1",
    "pretest:e2e": "pnpm build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "turbo typecheck",
    "db:up": "docker compose up -d",
    "db:generate": "pnpm --filter @educanvas/db generate",
    "db:migrate": "pnpm --filter @educanvas/db migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^2.0.5",
      "postcss": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
