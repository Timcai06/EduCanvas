{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:integration": {
      "cache": false,
      "env": ["TEST_DATABASE_URL"],
      "outputs": []
    },
    "typecheck": {}
  }
}
