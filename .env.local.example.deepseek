# Local DeepSeek development overlay. Merge these values into .env; never commit a real key.
EDUCANVAS_DEPLOYMENT_ENV=local
MODEL_GATEWAY_PROVIDER=deepseek
MODEL_GATEWAY_RUNTIME=native
MODEL_GATEWAY_ALLOW_DEEPSEEK=true
MODEL_GATEWAY_BASE_URL=https://api.deepseek.com
MODEL_GATEWAY_API_KEY=<your-deepseek-api-key>
MODEL_GATEWAY_PRIMARY_MODEL=deepseek-chat
MODEL_GATEWAY_FAST_MODEL=deepseek-chat
MODEL_GATEWAY_STRUCTURED_MODEL=deepseek-chat
